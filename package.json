{
  "name": "mundo-leo-lucas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mundo de Léo e Lucas — aplicativo infantil educativo (PWA) para dois irmãos.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource/baloo-2": "^5.0.0",
    "@fontsource/nunito": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
